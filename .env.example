# OILSHIP environment variables. Copy to .env (gitignored).

# Solana RPC endpoint used by the watch engine and CLI
OILSHIP_RPC_URL=https://api.mainnet-beta.solana.com

# Quorum endpoints (comma-separated). Used by watch for cross-RPC consensus
OILSHIP_QUORUM_ENDPOINTS=https://api.mainnet-beta.solana.com,https://api.devnet.solana.com

# Path to the Solana keypair (NEVER commit this file)
OILSHIP_KEYPAIR_PATH=~/.config/solana/id.json

# Network: mainnet-beta | devnet | testnet | localnet
OILSHIP_NETWORK=devnet

# Log level: trace | debug | info | warn | error
OILSHIP_LOG_LEVEL=info

# Anchor program id (Base58, 32 bytes)
OILSHIP_PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# Watch engine HTTP API port
OILSHIP_WATCH_PORT=8899

# Wreck Fund authority (set after deployment)
OILSHIP_WRECK_FUND_AUTHORITY=
